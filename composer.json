{
    "name": "mtasking/app",
    "description": "MTasking - Sistema de Gestión de Tareas",
    "type": "project",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "MTasking\\": "backend/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MTasking\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php vendor/bin/phpunit --colors=always --testdox",
        "test-coverage": "php vendor/bin/phpunit --coverage-text"
    }
}
